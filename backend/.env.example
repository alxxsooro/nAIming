# Optional: override CORS for production (comma-separated origins).
# Default in code includes localhost dev URLs; extend in app code or env when you add this.
# CORS_ORIGINS=https://your-app.vercel.app,https://your-api.example.com

# OpenAI — required for POST /generate (Studio).
OPENAI_API_KEY=

# Supabase — required for POST /generate to upload logos to Storage.
# Project URL (Project Settings → API).
SUPABASE_URL=
# Service role key (Project Settings → API). NEVER expose this in the frontend.
SUPABASE_SERVICE_ROLE_KEY=
# Public bucket where generated logos are stored.
SUPABASE_LOGOS_BUCKET=logos
